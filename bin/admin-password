#!/usr/bin/env bash
# Nastav heslo pro admin sekci
# Spusť z kořene projektu: bin/admin-password

docker compose exec web php -r "
echo 'Nové heslo: ';
system('stty -echo');
\$password = trim(fgets(STDIN));
system('stty echo');
echo PHP_EOL;
if (empty(\$password)) { echo 'Heslo nesmí být prázdné.' . PHP_EOL; exit(1); }
\$hash = password_hash(\$password, PASSWORD_DEFAULT);
\$dir = '/var/www/html/data';
if (!is_dir(\$dir)) mkdir(\$dir, 0750, true);
file_put_contents(\$dir . '/password.hash', \$hash);
echo 'Heslo bylo nastaveno.' . PHP_EOL;
"
